<Window x:Class="GraslandenGUI.Windows.ErrorSolveWindows.SolveSpeciesErrorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GraslandenGUI.Windows.ErrorSolveWindows"
        mc:Ignorable="d"
        Title="Pas soort aan" Height="auto" Width="500" SizeToContent="Height">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>

        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <TextBlock Text="Inventarisaties" Grid.ColumnSpan="2" Grid.Column="0" Grid.Row="0" HorizontalAlignment="Center" Margin="10"></TextBlock>
        <TextBlock Margin="20 5" Grid.Column="0" Grid.Row="1" Text="Naam"></TextBlock>
        <TextBlock Margin="20 5" Grid.Column="0" Grid.Row="2" Text="Vochtigheid"></TextBlock>
        <TextBlock Margin="20 5" Grid.Column="0" Grid.Row="3" Text="Zuurtegraad"></TextBlock>
        <TextBlock Margin="20 5" Grid.Column="0" Grid.Row="4" Text="Stikstofrijkdom"></TextBlock>
        <TextBlock Margin="20 5" Grid.Column="0" Grid.Row="6" Text="Nectarwaarde"></TextBlock>
        <TextBlock Margin="20 5" Grid.Column="0" Grid.Row="5" Text="Biodiversiteitswaarde"></TextBlock>
        <TextBlock Margin="20 5" Grid.Column="0" Grid.Row="7" Text="Soortenbeoordeling"></TextBlock>
        <TextBox Margin="20 5" Grid.Column="1" Grid.Row="1" Name="TextBoxName"></TextBox>
        <TextBox Margin="20 5" Grid.Column="1" Grid.Row="2" Name="TextBoxMoisture"></TextBox>
        <TextBox Margin="20 5" Grid.Column="1" Grid.Row="3" Name="TextBoxPh"></TextBox>
        <TextBox Margin="20 5" Grid.Column="1" Grid.Row="4" Name="TextBoxNitrogen"></TextBox>
        <TextBox Margin="20 5" Grid.Column="1" Grid.Row="5" Name="TextBoxNectar"></TextBox>
        <TextBox Margin="20 5" Grid.Column="1" Grid.Row="6" Name="TextBoxBiodiversity"></TextBox>
        <ComboBox Margin="20 5 20 10" Grid.Column="1" Grid.Row="7" Name="ComboBoxRating"></ComboBox>
        <Button Margin="20 10" Content="Terug" Grid.ColumnSpan="2" HorizontalAlignment="Left" Padding="10 2" Grid.Row="8"></Button>
        <Button Margin="20 10" Content="Aanpassen" Grid.ColumnSpan="2" HorizontalAlignment="Right" Padding="10 2" Grid.Row="8"></Button>
    </Grid>
</Window>

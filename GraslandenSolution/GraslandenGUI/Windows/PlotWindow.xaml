<Window x:Class="GraslandenGUI.Windows.PlotWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GraslandenGUI.Windows"
        mc:Ignorable="d"
        Title="Grasland Info" Height="500" Width="400">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
        </Grid.RowDefinitions>
        <TextBlock Text="Grasland ___" Grid.Row="0" HorizontalAlignment="Center" Margin="10"></TextBlock>
        <Grid Grid.Row="1" Margin="10">
        </Grid>
        <TextBlock Grid.Row="2" Text="Metingen" Padding="10 0"></TextBlock>
        <ListBox Grid.Row="3" Margin="10" Name="ListBoxMeasurements"></ListBox>
        <Button Grid.Row="4" Content="Terug" Margin="10" Click="ButtonBack"></Button>
    </Grid>
</Window>

<Window x:Class="GraslandenGUI.Windows.PlotWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GraslandenGUI.Windows"
        mc:Ignorable="d"
        Title="Grasland Info" Height="500" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
        </Grid.RowDefinitions>
        <TextBlock Text="" Grid.Row="0" HorizontalAlignment="Center" Margin="10" Name="TextBlockTitle"></TextBlock>
        <Grid Grid.Row="1" Margin="10" Name="GridInfo">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"></RowDefinition>
                <RowDefinition Height="auto"></RowDefinition>
                <RowDefinition Height="auto"></RowDefinition>
                <RowDefinition Height="auto"></RowDefinition>
                <RowDefinition Height="auto"></RowDefinition>
                <RowDefinition Height="auto"></RowDefinition>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
                <ColumnDefinition Width="auto"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Aantal soorten" Grid.Row="0" Grid.Column="0" Margin="10 2"></TextBlock>
            <TextBlock Text="Gem. Vochtigheid" Grid.Row="1" Grid.Column="0" Margin="10 2"></TextBlock>
            <TextBlock Text="Gem. Zuurtegraad" Grid.Row="2" Grid.Column="0" Margin="10 2"></TextBlock>
            <TextBlock Text="Gem. Stikstofrijkdom" Grid.Row="0" Grid.Column="2" Margin="10 2"></TextBlock>
            <TextBlock Text="Gem. Nectarwaarde" Grid.Row="1" Grid.Column="2" Margin="10 2"></TextBlock>
            <TextBlock Text="Gem. Biodiversiteitswaarde" Grid.Row="2" Grid.Column="2" Margin="10 2"></TextBlock>
        </Grid>
        <TextBlock Grid.Row="2" Text="Metingen" Padding="10 0"></TextBlock>
        <DataGrid Grid.Row="3" Margin="10" Name="DataGridMeasurements" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Soort" Binding="{Binding Species.Name}"></DataGridTextColumn>
                <DataGridTextColumn Header="Bedekkingsklasse" Binding="{Binding Coverage}"></DataGridTextColumn>
                <DataGridTextColumn Header="Vocht" Binding="{Binding Species.Moisture}"></DataGridTextColumn>
                <DataGridTextColumn Header="Zuurtegraad" Binding="{Binding Species.Ph}"></DataGridTextColumn>
                <DataGridTextColumn Header="Stikstofrijkdom" Binding="{Binding Species.Nitrogen}"></DataGridTextColumn>
                <DataGridTextColumn Header="Nectarwaarde" Binding="{Binding Species.Nectarvalue}"></DataGridTextColumn>
                <DataGridTextColumn Header="Biodiversiteitswaarde" Binding="{Binding Species.Biodiversity}"></DataGridTextColumn>
                <DataGridTextColumn Header="Beoordeling" Binding="{Binding Species.Rating}"></DataGridTextColumn>
            </DataGrid.Columns>
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Verwijderen" Click="DeleteMeasurement_Click"></MenuItem>
                </ContextMenu>
            </DataGrid.ContextMenu>
        </DataGrid>
        <Button Grid.Row="4" Content="Terug" Margin="10" Click="ButtonBack" HorizontalAlignment="Left" Padding="50 2"></Button>
        <Button Grid.Row="4" Content="Nieuwe Meting" Margin="10" Click="NewMeasurement_Click" HorizontalAlignment="Right" Padding="50 2"></Button>
    </Grid>
</Window>

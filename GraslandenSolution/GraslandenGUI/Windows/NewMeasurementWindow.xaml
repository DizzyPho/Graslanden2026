<Window x:Class="GraslandenGUI.Windows.NewMeasurementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GraslandenGUI.Windows"
        mc:Ignorable="d"
        Title="NewMeasurementWindow" Height="auto" Width="400" SizeToContent="Height">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <TextBlock Margin="10 15" Text="Nieuwe meting" Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center" Grid.ColumnSpan="2"></TextBlock>
        <TextBlock Margin="10" Text="Soort" Grid.Row="1" Grid.Column="0"></TextBlock>
        <TextBlock Margin="10" Text="Bedekkingsklasse" Grid.Row="2" Grid.Column="0"></TextBlock>
        <TextBox Name="TextBoxSpecies" Margin="10" Grid.Row="1" Grid.Column="1"></TextBox>
        <TextBox Name="TextBoxCoverage" Margin="10" Grid.Row="2" Grid.Column="1"></TextBox>
        <Button Grid.Row="3" Grid.Column="1" Content="Toevoegen" Margin="10" HorizontalAlignment="Right" Padding="10 2" Click="ButtonAdd_Click"></Button>
        <Button Grid.Row="3" Grid.Column="0" Content="Terug" Margin="10" HorizontalAlignment="Left" Padding="10 2" Click="ButtonBack_Click"></Button>
    </Grid>
</Window>
